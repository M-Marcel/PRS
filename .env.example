# === Chain Configuration ===
# "mainnet" for Base Mainnet, anything else defaults to Base Sepolia
NEXT_PUBLIC_CHAIN=sepolia

# WalletConnect Project ID — get from https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id

# RPC URL for Base chain (Alchemy, Infura, or public)
NEXT_PUBLIC_RPC_URL=https://sepolia.base.org

# === Database ===
DATABASE_URL=postgresql://user:password@localhost:5432/actx_presale

# === KYC Provider (Persona recommended) ===
PERSONA_API_KEY=your_persona_api_key
PERSONA_TEMPLATE_ID=your_persona_template_id
PERSONA_WEBHOOK_SECRET=your_persona_webhook_secret

# === Admin Configuration ===
# Comma-separated list of admin wallet addresses (checksummed)
# Server-side validation
ADMIN_WALLETS=0xYourAdminWallet1,0xYourAdminWallet2
# Client-side UI gate (same list, exposed to browser for UI-only access control)
NEXT_PUBLIC_ADMIN_WALLETS=0xYourAdminWallet1,0xYourAdminWallet2

# === Presale Timing (ISO 8601) ===
NEXT_PUBLIC_PRESALE_OPEN_DATE=2026-05-01T00:00:00Z
NEXT_PUBLIC_PRESALE_CLOSE_DATE=2026-05-08T00:00:00Z
NEXT_PUBLIC_DEX_LAUNCH_DATE=2026-05-10T00:00:00Z
NEXT_PUBLIC_UPGRADE_CUTOFF_DATE=2026-04-30T00:00:00Z

# === Optional: Analytics ===
NEXT_PUBLIC_POSTHOG_KEY=your_posthog_key
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
