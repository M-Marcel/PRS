generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Founder {
  id              String       @id @default(cuid())
  walletAddress   String       @unique @db.VarChar(42)
  tier            Int          @default(0)              // 0=None, 1=Elite, 2=Legend

  // KYC
  kycProvider      String?                              // "persona" | "sumsub"
  kycSessionId     String?      @unique
  kycStatus        String       @default("pending")     // pending | approved | rejected
  kycCompletedAt   DateTime?

  // Genesis Sprint
  sprintSessions   SprintSession[]
  sprintCompleted  Boolean      @default(false)
  sprintCompletedAt DateTime?

  // Presale
  registeredOnChain Boolean     @default(false)
  sprintMarkedOnChain Boolean   @default(false)
  purchaseTxHash    String?
  tokensPurchased   String?                             // BigInt as string
  usdcSpent         String?                             // BigInt as string
  purchasedAt       DateTime?

  // Metadata
  email             String?
  naxumAccountId    String?      @unique                // Link to NaXum SaaS account
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@index([walletAddress])
  @@index([kycStatus])
  @@index([tier])
}

model SprintSession {
  id              String    @id @default(cuid())
  founderId       String
  founder         Founder   @relation(fields: [founderId], references: [id])

  sessionDate     DateTime  @db.Date                    // Calendar day of session
  actionHash      String    @unique                     // From BSI oracle
  verifiedOnChain Boolean   @default(false)
  txHash          String?

  createdAt       DateTime  @default(now())

  @@unique([founderId, sessionDate])                    // One session per day per founder
  @@index([founderId])
}

model PresaleEvent {
  id              String    @id @default(cuid())
  eventType       String                                // "purchase" | "tge_claim" | "vest_claim"
  walletAddress   String    @db.VarChar(42)
  txHash          String    @unique
  blockNumber     BigInt
  tokenAmount     String                                // BigInt as string
  usdcAmount      String?                               // BigInt as string (purchases only)
  tier            Int?

  createdAt       DateTime  @default(now())

  @@index([walletAddress])
  @@index([eventType])
}

model AdminAction {
  id              String    @id @default(cuid())
  adminAddress    String    @db.VarChar(42)
  action          String                                // "register_founder" | "mark_sprint" | "open" | "close" | "tge"
  targetAddress   String?   @db.VarChar(42)
  txHash          String?
  metadata        Json?

  createdAt       DateTime  @default(now())

  @@index([adminAddress])
}
